# =
# RUMS Frontend — Environment Configuration
# =

# ── Application ───────────────────────────────────────────────
APP_NAME=
APP_FULL_NAME=
APP_VERSION=
APP_ENV=
APP_DEBUG=
APP_TIMEZONE=
APP_URL=

# ── REST API ──────────────────────────────────────────────────
# URL of the standalone RUMS REST API (no trailing slash)
API_URL=

# ── Database (used only for audit_log and permitted exceptions) ─
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASS=
DB_CHARSET=

# ── Session ───────────────────────────────────────────────────
SESSION_NAME=
SESSION_LIFETIME=
# SESSION_SECURE is auto-detected from HTTPS; only set this to override
# SESSION_SECURE=
SESSION_HTTPONLY=
SESSION_SAMESITE=

# ── Security ──────────────────────────────────────────────────
APP_KEY=

# ── Currency ──────────────────────────────────────────────────
CURRENCY_SYMBOL=
CURRENCY_CODE=

# ── M-Pesa ────────────────────────────────────────────────────
MPESA_ENV=
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=

# ── Logging ───────────────────────────────────────────────────
LOG_CHANNEL=
LOG_PATH=
