Options -Indexes -MultiViews
ServerSignature Off

# ── Custom error pages ────────────────────────────────────────
ErrorDocument 400 /errors/error.php
ErrorDocument 403 /errors/error.php
ErrorDocument 404 /errors/error.php
ErrorDocument 405 /errors/error.php
ErrorDocument 429 /errors/error.php
ErrorDocument 500 /errors/error.php
ErrorDocument 502 /errors/error.php
ErrorDocument 503 /errors/error.php

# ── Force HTTPS in production ─────────────────────────────────
# Uncomment when SSL certificate is installed:
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

RewriteEngine On

# ── Block access to sensitive directories & files ─────────────
RewriteRule ^(\.env|\.git|composer\.(json|lock)|package\.json|Dockerfile|docker-compose.*) - [F,L]
RewriteRule ^(config|includes|services|database)/ - [F,L]
RewriteRule \.(sql|log|sh|bat|md)$ - [F,L]

# ── Pass Authorization header to PHP (some server configs strip it) ──
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# ── Web app — standard PHP fallback ──────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# ── Security headers (Apache mod_headers) ────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options           "DENY"
    Header always set X-Content-Type-Options    "nosniff"
    Header always set X-XSS-Protection         "1; mode=block"
    Header always set Referrer-Policy          "strict-origin-when-cross-origin"
    Header always set Permissions-Policy       "geolocation=(), microphone=(), camera=()"

    # Remove Server header
    Header unset Server
    Header always unset X-Powered-By

    # Cache static assets
    <FilesMatch "\.(css|js|jpg|jpeg|png|gif|ico|svg|woff|woff2|webp)$">
        Header set Cache-Control "public, max-age=2592000, immutable"
    </FilesMatch>

    # No cache for PHP responses
    <FilesMatch "\.php$">
        Header set Cache-Control "no-store, no-cache, must-revalidate"
    </FilesMatch>
</IfModule>

# ── Compression ───────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
    AddOutputFilterByType DEFLATE application/json text/plain application/xml
</IfModule>

# ── File upload size ──────────────────────────────────────────
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 12M
    php_value max_execution_time 60
    php_value memory_limit 256M
</IfModule>
